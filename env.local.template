# Copy this file to .env and fill in real values.
# Keep .env private and uncommitted.

APP_ENV=development
APP_MODE=live

# Live adapter config
# Example: https://your-live-adapter.example.com/runtime
BINANCE_SKILLS_BASE_URL=
BINANCE_API_KEY=
BINANCE_API_SECRET=

# API server
API_HOST=0.0.0.0
API_PORT=8000

# API security
API_AUTH_ENABLED=false
API_AUTH_KEY=
API_RATE_LIMIT_ENABLED=true
API_RATE_LIMIT_REQUESTS=60
API_RATE_LIMIT_WINDOW_SECONDS=60

# Bridge settings
BRIDGE_LIVE_ENABLED=false
BRIDGE_DEFAULT_CHAIN_ID=56
BRIDGE_HTTP_TIMEOUT_SECONDS=20
BRIDGE_HTTP_RETRIES=2
BRIDGE_HEALTHCHECK_ENABLED=true

# Binance Square posting
BINANCE_SQUARE_API_KEY=
BINANCE_SQUARE_API_BASE_URL=https://www.binance.com
BINANCE_SQUARE_API_PUBLISH_PATH=/bapi/composite/v1/public/pgc/openApi/content/add
BINANCE_SQUARE_API_KEY_HEADER=X-Square-OpenAPI-Key

# Optional
COINMARKETCAP_API_KEY=
