# Runtime
APP_ENV=development
APP_MODE=mock

# Live adapter config
# Examples:
# BINANCE_SKILLS_BASE_URL=file:///absolute/path/to/payloads
# BINANCE_SKILLS_BASE_URL=https://adapter.example.com/runtime
BINANCE_SKILLS_BASE_URL=
BINANCE_API_KEY=
BINANCE_API_SECRET=

# API server
API_HOST=0.0.0.0
API_PORT=8000

# Binance Square posting
BINANCE_SQUARE_API_KEY=
BINANCE_SQUARE_API_BASE_URL=https://www.binance.com
BINANCE_SQUARE_API_PUBLISH_PATH=/bapi/composite/v1/public/pgc/openApi/content/add
BINANCE_SQUARE_API_KEY_HEADER=X-Square-OpenAPI-Key

# Optional direct market quote source for /price
COINMARKETCAP_API_KEY=

# Telegram / messaging placeholders
TELEGRAM_BOT_TOKEN=

# OpenClaw-related placeholders
OPENCLAW_WORKSPACE=
OPENCLAW_AGENT_NAME=Bibipilot

# Scheduled Square diary defaults
SQUARE_DIARY_TIMEZONE=Asia/Phnom_Penh
SQUARE_DIARY_MORNING=07:30
SQUARE_DIARY_NIGHT=21:30
